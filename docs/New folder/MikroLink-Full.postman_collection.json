{
  "info": {"name": "MikroLink - Full API (User + Driver)", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:5000"},
    {"key": "userToken", "value": ""},
    {"key": "userRefreshToken", "value": ""},
    {"key": "driverToken", "value": ""},
    {"key": "driverRefreshToken", "value": ""},
