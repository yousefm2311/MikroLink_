          {"name": "Verify (GET)", "request": {"method": "GET", "url": "{{baseUrl}}/api/user/verify/{{token}}"}},
          {"name": "Login (email)", "event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j = pm.response.json();","if(j && j.data){"," if(j.data.accessToken){ pm.environment.set('userToken', j.data.accessToken); }"," if(j.data.refreshToken){ pm.environment.set('userRefreshToken', j.data.refreshToken); }","}"]}}], "request": {"method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/auth/login", "body": {"mode":"raw","raw":"{\n  \"email\": \"ali@example.com\",\n  \"password\": \"secret123\"\n}"}}},
          {"name": "Login (phone)", "event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j = pm.response.json();","if(j && j.data){"," if(j.data.accessToken){ pm.environment.set('userToken', j.data.accessToken); }"," if(j.data.refreshToken){ pm.environment.set('userRefreshToken', j.data.refreshToken); }","}"]}}], "request": {"method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/auth/login", "body": {"mode":"raw","raw":"{\n  \"phone\": \"01000000000\",\n  \"password\": \"secret123\"\n}"}}},
