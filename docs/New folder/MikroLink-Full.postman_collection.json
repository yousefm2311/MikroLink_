  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var url = pm.request.url.toString();",
          "var token = null;",
          "if (url.indexOf('/api/user/') !== -1) { token = pm.environment.get('userToken'); }",
          "else if (url.indexOf('/api/driver/') !== -1 || url.indexOf('/api/profile') !== -1 || url.indexOf('/api/trip') !== -1 || url.indexOf('/api/fuel') !== -1 || url.indexOf('/api/oil') !== -1 || url.indexOf('/api/vehicle') !== -1 || url.indexOf('/api/maintenance') !== -1 || url.indexOf('/api/support') !== -1 || url.indexOf('/api/summary') !== -1 || url.indexOf('/api/earnings') !== -1 || url.indexOf('/api/location') !== -1 || url.indexOf('/api/settings') !== -1 || url.indexOf('/api/rating') !== -1 || url.indexOf('/api/reminder') !== -1) { token = pm.environment.get('driverToken'); }",
          "if (token) { pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token }); }"
        ]
      }
    }
  ],
