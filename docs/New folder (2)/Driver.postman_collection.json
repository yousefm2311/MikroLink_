{
  "info": {"name": "MikroLink – Driver APIs", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},
  "variable": [
    {"key":"baseUrl","value":"http://localhost:5000"},
    {"key":"driverToken","value":""},
    {"key":"tripId","value":""},
    {"key":"reminderId","value":""}
  ],
  "item": [
    {"name":"Auth","item":[
      {"name":"Signup","request":{"method":"POST","url":"{{baseUrl}}/api/driver/signup","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"fullName\":\"Driver One\",\n  \"phone\":\"0100\",\n  \"email\":\"driver@example.com\",\n  \"password\":\"pass1234\"\n}"}}},
      {"name":"Resend Verification","request":{"method":"POST","url":"{{baseUrl}}/api/driver/resend-verification","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\":\"driver@example.com\"\n}"}}},
      {"name":"Login","request":{"method":"POST","url":"{{baseUrl}}/api/driver/login","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\":\"driver@example.com\",\n  \"password\":\"pass1234\"\n}"}}},
      {"name":"Forgot Password","request":{"method":"POST","url":"{{baseUrl}}/api/driver/forgot-password","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\":\"driver@example.com\"\n}"}}},
      {"name":"Verify Reset Code","request":{"method":"POST","url":"{{baseUrl}}/api/driver/verify-reset-code","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\":\"driver@example.com\",\n  \"code\":\"123456\"\n}"}}},
      {"name":"Reset Password","request":{"method":"POST","url":"{{baseUrl}}/api/driver/reset-password","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\":\"driver@example.com\",\n  \"code\":\"123456\",\n  \"newPassword\":\"pass5678\"\n}"}}},
      {"name":"Change Password","request":{"method":"POST","url":"{{baseUrl}}/api/driver/change-password","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"currentPassword\":\"pass1234\",\n  \"newPassword\":\"pass5678\"\n}"}}},
      {"name":"Refresh","request":{"method":"POST","url":"{{baseUrl}}/api/driver/refresh","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"refreshToken\":\"<token>\"\n}"}}},
      {"name":"Logout","request":{"method":"POST","url":"{{baseUrl}}/api/driver/logout","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"refreshToken\":\"<token>\"\n}"}}}
    ]},
    {"name":"Profile","item":[
      {"name":"Get","request":{"method":"GET","url":"{{baseUrl}}/api/profile/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Update","request":{"method":"PUT","url":"{{baseUrl}}/api/profile/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"fullName\":\"Updated Name\"\n}"}}}
    ]},
    {"name":"Vehicle","item":[
      {"name":"Get","request":{"method":"GET","url":"{{baseUrl}}/api/vehicle/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Upsert","request":{"method":"POST","url":"{{baseUrl}}/api/vehicle/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"plateNumber\":\"ABC-123\",\n  \"model\":\"Sedan\"\n}"}}}
    ]},
    {"name":"Maintenance","item":[
      {"name":"Create","request":{"method":"POST","url":"{{baseUrl}}/api/maintenance/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"type\":\"Oil Change\",\n  \"odometer\":12000\n}"}}},
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/maintenance/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Oil","item":[
      {"name":"Update","request":{"method":"POST","url":"{{baseUrl}}/api/oil/update","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"odometer\":15000,\n  \"nextOilChange\":20000\n}"}}},
      {"name":"Get","request":{"method":"GET","url":"{{baseUrl}}/api/oil/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Reminder","item":[
      {"name":"Create","request":{"method":"POST","url":"{{baseUrl}}/api/reminder/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"title\":\"Change Tires\"\n}"}}},
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/reminder/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Mark Read","request":{"method":"PUT","url":"{{baseUrl}}/api/reminder/{{reminderId}}/read","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Trip","item":[
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/trip/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Start","request":{"method":"POST","url":"{{baseUrl}}/api/trip/start","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"passengerName\":\"User X\",\n  \"pickupLocation\":\"A\",\n  \"dropoffLocation\":\"B\"\n}"}}},
      {"name":"Complete","request":{"method":"POST","url":"{{baseUrl}}/api/trip/{{tripId}}/complete","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Current","request":{"method":"GET","url":"{{baseUrl}}/api/trip/current","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Cancel","request":{"method":"POST","url":"{{baseUrl}}/api/trip/{{tripId}}/cancel","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Earnings","item":[
      {"name":"Today","request":{"method":"GET","url":"{{baseUrl}}/api/earnings/today","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Month","request":{"method":"GET","url":"{{baseUrl}}/api/earnings/month","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Rating","item":[
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/rating/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Notification","item":[
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/notification/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Status","item":[
      {"name":"Toggle","request":{"method":"PUT","url":"{{baseUrl}}/api/status/toggle","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Location","item":[
      {"name":"Live Update","request":{"method":"POST","url":"{{baseUrl}}/api/location/live","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"latitude\":30.0,\n  \"longitude\":31.0\n}"}}},
      {"name":"Get Live","request":{"method":"GET","url":"{{baseUrl}}/api/location/live","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Available (public)","request":{"method":"GET","url":"{{baseUrl}}/api/location/available?latitude=30&longitude=31","header":[]}},
      {"name":"Add Trip Point","request":{"method":"POST","url":"{{baseUrl}}/api/location/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"tripId\":\"{{tripId}}\",\n  \"latitude\":30.0,\n  \"longitude\":31.0\n}"}}},
      {"name":"Trip Points","request":{"method":"GET","url":"{{baseUrl}}/api/location/{{tripId}}","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Summary","item":[
      {"name":"Overview","request":{"method":"GET","url":"{{baseUrl}}/api/summary/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Weekly","request":{"method":"GET","url":"{{baseUrl}}/api/summary/weekly","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Support","item":[
      {"name":"Create","request":{"method":"POST","url":"{{baseUrl}}/api/support/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"message\":\"Need help\"\n}"}}},
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/support/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Fuel","item":[
      {"name":"Create","request":{"method":"POST","url":"{{baseUrl}}/api/fuel/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"liters\":30,\n  \"cost\":200\n}"}}},
      {"name":"List","request":{"method":"GET","url":"{{baseUrl}}/api/fuel/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Summary","request":{"method":"GET","url":"{{baseUrl}}/api/fuel/summary","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}}
    ]},
    {"name":"Chat","item":[
      {"name":"Trip Messages","request":{"method":"GET","url":"{{baseUrl}}/api/chat/{{tripId}}","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"}]}},
      {"name":"Send Message (REST)","request":{"method":"POST","url":"{{baseUrl}}/api/chat/","header":[{"key":"Authorization","value":"Bearer {{driverToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"tripId\":\"{{tripId}}\",\n  \"senderId\":\"<driverId>\",\n  \"text\":\"Hi\"\n}"}}}
    ]}
  ]
}

