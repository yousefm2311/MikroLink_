            { "name": "Send Message", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": "{{baseUrl}}/api/chat", "body": { "mode": "raw", "raw": "{\n  \"tripId\": \"{{tripId}}\",\n  \"senderId\": \"{{driverId}}\",\n  \"text\": \"Hello\"\n}" } } }
          ]
        }
      ]
    }
  ]
}
